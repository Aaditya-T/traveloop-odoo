# Neon Postgres URL for the team database, or a local Postgres URL for offline work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/traveloop?sslmode=require"

# Used to sign Traveloop's session cookie. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-secret"

# Optional, used when rendering share URLs in the UI.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional seed-time admin account. Set before `npm run db:seed` when you want `/admin` access.
TRAVELOOP_ADMIN_EMAIL="admin@traveloop.dev"
TRAVELOOP_ADMIN_PASSWORD="replace-me-with-8-plus-characters"
TRAVELOOP_ADMIN_NAME="Traveloop Admin"

# Optional local showcase data. Leave unset in production.
TRAVELOOP_SEED_SHOWCASE="false"
TRAVELOOP_SHOWCASE_PASSWORD=""
