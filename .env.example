# Neon Postgres URL for the team database, or a local Postgres URL for offline work.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/traveloop?sslmode=require"

# Used to sign Traveloop's session cookie. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-secret"

# Optional, used when rendering share URLs in the UI.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional seed-time admin account. Set before `npm run db:seed` when you want `/admin` access.
# The seed script loads both .env and .env.local (local wins). Log in at /login with this email.
TRAVELOOP_ADMIN_EMAIL="admin@traveloop.dev"
TRAVELOOP_ADMIN_PASSWORD="replace-me-with-8-plus-characters"
TRAVELOOP_ADMIN_NAME="Traveloop Admin"

# Optional local showcase data. Leave unset in production.
# When TRAVELOOP_SEED_SHOWCASE=true and TRAVELOOP_SHOWCASE_PASSWORD is set (8+ chars recommended),
# the seed loads ~8 demo users (shared password) and ~10 public trips with likes/saves/comments.
#
# Accounts (same password): traveller@example.com, mira.chang@traveloop.demo, jules.renard@traveloop.demo,
# sam.diaz@traveloop.demo, nina.patel@traveloop.demo, omar.haddad@traveloop.demo,
# zoe.mbatha@traveloop.demo, alex.volkov@traveloop.demo
#
# Re-seeding wipes itinerary lines that referenced catalog activities for each seeded city before
# recreating catalog rows. Showcase pass also deletes trips owned only by those demo emails.
TRAVELOOP_SEED_SHOWCASE="false"
TRAVELOOP_SHOWCASE_PASSWORD=""


# --- Cloudflare R2 (S3-compatible uploads) — all required for direct uploads in the UI ---
# Create an R2 bucket, then: R2 → Manage R2 API Tokens → Create API token (Object Read & Write on that bucket).
# In the bucket settings, allow public access OR attach a custom domain / r2.dev public URL for reads.
#
# CORS (R2 bucket → Settings → CORS): allow your app origin, methods PUT,GET,HEAD, and headers Content-Type.
# Example rule: Origin https://your-app.com, Methods PUT GET HEAD, Headers Content-Type
#
R2_ACCOUNT_ID=          # Cloudflare account id (subdomain in the S3 API endpoint)
R2_ACCESS_KEY_ID=       # From the R2 API token
R2_SECRET_ACCESS_KEY=   # From the R2 API token
R2_BUCKET=              # Bucket name (alias: R2_BUCKET_NAME)
R2_PUBLIC_BASE_URL=     # Public base URL for objects, no trailing slash (custom domain or https://pub-xxxxx.r2.dev)
#                         # Optional: prisma/seed maps non-HTTP media paths through this base (see seedMedia in prisma/seed.ts).
#
# Optional: override the S3 endpoint if not using the default host:
# R2_S3_API=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

